# Copy this file to .env and fill in real values. .env is gitignored.
# Postgres connection string (this project uses the pgvector/pgvector image).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# JWT secret for signing tokens. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=GENERATE_A_LONG_RANDOM_VALUE_HERE
